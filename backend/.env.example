# ============================================================================
# Activity (Skhodka) backend — example environment
# Copy to .env and fill in real values. NEVER commit a real .env.
# The values below are safe dev defaults / placeholders only.
# ============================================================================

# --- App ---
APP_ENV=development                 # development | production
APP_SECRET_KEY=change-me-to-a-32-byte-random-string   # REQUIRED in prod; used to sign JWTs
API_V1_PREFIX=/api/v1
CORS_ORIGINS=*                      # CSV of allowed origins; "*" is dev-only (rejected in prod)
AUTO_CREATE_TABLES=true             # dev only; use Alembic in prod

# --- Database (PostgreSQL + PostGIS) ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=skhodka
POSTGRES_PASSWORD=change-me
POSTGRES_DB=skhodka
DATABASE_URL=postgresql+asyncpg://skhodka:change-me@db:5432/skhodka
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# --- Redis (OTP, rate limiting, WebSocket pub/sub, presence) ---
REDIS_URL=redis://redis:6379/0

# --- JWT ---
JWT_ALG=HS256
ACCESS_TOKEN_TTL_MIN=30
REFRESH_TOKEN_TTL_DAYS=30

# --- OTP / SMS ---
OTP_TTL_SECONDS=300
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SEC=60
SMS_PROVIDER=stub                   # stub (logs code) | smsc
SMS_SENDER=                         # optional sender name
SMSC_LOGIN=                         # SMSC.ru login (only if SMS_PROVIDER=smsc)
SMSC_PASSWORD=                      # SMSC.ru password (only if SMS_PROVIDER=smsc)

# --- Rate limiting (per-IP, per-minute) ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MIN=120

# --- Per-user limits (spam-prone actions) ---
USER_RATE_LIMIT_ENABLED=true
USER_RL_EVENTS_PER_HOUR=10
USER_RL_JOINS_PER_HOUR=30
USER_RL_REPORTS_PER_HOUR=10
USER_RL_MESSAGES_PER_MIN=60

# --- Storage: local | s3 ---
STORAGE_BACKEND=local
MEDIA_ROOT=/app/media
MEDIA_PUBLIC_URL=http://localhost:8000/media
MAX_UPLOAD_MB=10
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
IMAGE_MAX_DIMENSION=1600

# --- S3 / MinIO (only if STORAGE_BACKEND=s3) ---
S3_ENDPOINT=                        # empty = AWS; MinIO e.g. http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=skhodka-media
S3_ACCESS_KEY=                      # your S3/MinIO access key
S3_SECRET_KEY=                      # your S3/MinIO secret key
S3_PUBLIC_URL=                      # base URL objects are served from

# --- Push: FCM (Android) ---
FCM_PROJECT_ID=                     # Firebase project id
FCM_CREDENTIALS_JSON=               # path to service-account JSON (keep out of git)

# --- Push: APNs (iOS) ---
APNS_KEY_PATH=                      # path to AuthKey_XXXX.p8 (keep out of git)
APNS_KEY_ID=                        # APNs key id
APNS_TEAM_ID=                       # Apple developer team id
APNS_BUNDLE_ID=com.skhodka.app
APNS_USE_SANDBOX=true               # true for dev builds; false for TestFlight/App Store
